<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0FF">

    <!-- 主内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部导航栏 -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#7C4DFF"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <ImageButton
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="@android:color/transparent"
                android:contentDescription="菜单"
                android:padding="12dp"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="物理AI助手"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnNewChat"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_input_add"
                android:background="@android:color/transparent"
                android:contentDescription="新建对话"
                android:padding="12dp"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <!-- 聊天区域 -->
        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/chatLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <!-- 底部输入区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="#FFFFFF"
            android:elevation="8dp">

            <EditText
                android:id="@+id/inputMessage"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="输入物理问题..."
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:background="@drawable/input_bg"
                android:textSize="14sp"
                android:maxLines="3" />

            <Button
                android:id="@+id/btnSend"
                android:layout_width="56dp"
                android:layout_height="44dp"
                android:text="发送"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_round"
                android:gravity="center"
                android:layout_marginLeft="8dp"
                android:padding="0dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </LinearLayout>

    <!-- 侧边抽屉 -->
    <LinearLayout
        android:id="@+id/drawerContent"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#F8F6FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#7C4DFF"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 对话历史"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/conversationCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 个对话"
                android:textSize="13sp"
                android:textColor="#D0D0FF" />
        </LinearLayout>

        <Button
            android:id="@+id/btnNewFromDrawer"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_margin="12dp"
            android:text="➕ 新建对话"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_round"
            android:gravity="center"
            android:stateListAnimator="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8E0F0"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="   最近对话"
            android:textSize="12sp"
            android:textColor="#999999"
            android:paddingTop="12dp"
            android:paddingBottom="4dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp">

            <LinearLayout
                android:id="@+id/conversationList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
